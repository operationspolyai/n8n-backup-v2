        "query": "SELECT \n    \"Members\".\"email\", \n    \"Members\".\"ClickUpID\", \n    \"Department\".\"ClickUpAssignOtherListID\" AS \"OtherDepartmentID\",\n    \"Department\".\"departmentName\"\nFROM \"Members\"\nJOIN \"MemberRole\" ON \"Members\".\"id\" = \"MemberRole\".\"memberID\"\nJOIN \"MemberDepartment\" ON \"Members\".\"id\" = \"MemberDepartment\".\"memberID\"\nJOIN \"Department\" ON \"Department\".\"id\" = \"MemberDepartment\".\"departmentID\"\nWHERE \"MemberRole\".\"roleID\" = 1 \n  AND \"Members\".\"ClickUpID\" IS NOT NULL;",

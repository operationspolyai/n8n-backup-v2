    {
      "parameters": {
        "jsCode": "// 1. Get the raw lists from the nodes\nconst allMembersRaw = $(\"Get All Members1\").all();\nconst allVPsRaw = $(\"Get VPs\").all();\n\n// 2. Deduplicate Members by ClickUpID using a Map\n// This ensures that even if SQL returns a person twice, they only appear once in our list\nconst uniqueMembersMap = new Map();\nallMembersRaw.forEach(m => {\n  const id = m.json.ClickUpID?.toString();\n  if (id && !uniqueMembersMap.has(id)) {\n    uniqueMembersMap.set(id, m.json);\n  }\n});\n\n// 3. Create a Set of VP IDs for fast lookup\nconst vpIds = new Set(allVPsRaw.map(vp => vp.json.ClickUpID?.toString()));\n\n// 4. Build the unique entries array\nconst entries = Array.from(uniqueMembersMap.values()).map(member => {\n  const memberId = member.ClickUpID.toString();\n  const isVP = vpIds.has(memberId);\n\n  return {\n    \"id\": parseInt(memberId),\n    \"kind\": \"user\",\n    \"permission_level\": isVP ? 5 : null\n  };\n});\n\n// 5. CRITICAL: Return an array with exactly ONE object \n// This prevents n8n from looping and duplicating the output\nreturn [{\n  json: {\n    body: JSON.stringify({\n      \"entries\": entries,\n      \"private\": true\n    })\n  }\n}];"
      },

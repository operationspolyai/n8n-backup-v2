    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    \"Department\".\"ClickUpFolderID\",\n    \"Department\".\"departmentName\",\n    STRING_AGG(\"Members\".\"ClickUpID\"::text, ', ') AS \"UserIDs\",\n    STRING_AGG(\"Members\".\"email\", ', ') AS \"Emails\"\nFROM \"Department\"\nLEFT JOIN \"MemberDepartment\" \n    ON \"Department\".\"id\" = \"MemberDepartment\".\"departmentID\"\nLEFT JOIN \"Members\" \n    ON \"MemberDepartment\".\"memberID\" = \"Members\".\"id\" \n    AND \"Members\".\"ClickUpID\" IS NOT NULL\nGROUP BY \n    \"Department\".\"id\", \n    \"Department\".\"ClickUpFolderID\", \n    \"Department\".\"departmentName\";",
        "options": {}

    {
      "parameters": {
        "jsCode": "// 1. Get the Master List of all club members\nconst allClubMembers = $(\"Get All Members\").all();\n\n// 2. Reference the Loop node directly as requested\nconst folderItems = $(\"Loop Over Each Department Folder\").all();\n\nreturn folderItems.map(item => {\n  // 3. Identify who SHOULD have permission 5 in this folder\n  const deptIdsRaw = item.json.UserIDs || \"\";\n  const deptIds = deptIdsRaw.split(',').map(id => id.trim());\n\n  // 4. Build the entries list for EVERY member in the club\n  const entries = allClubMembers.map(member => {\n    const memberId = member.json.ClickUpID.toString();\n    const isDeptMember = deptIds.includes(memberId);\n\n    return {\n      \"id\": parseInt(memberId),\n      \"kind\": \"user\",\n      \"permission_level\": isDeptMember ? 5 : null\n    };\n  });\n\n  // 5. Output the folder data + the stringified body\n  return {\n    json: {\n      ...item.json, // Preserves ClickUpFolderID, departmentName, UserIDs, Emails\n      body: JSON.stringify({\n        \"entries\": entries\n      })\n    }\n  };\n});"
      },
